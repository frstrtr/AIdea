# Copy this file to .env (which is gitignored) and fill in real values.
# Both server.py and bot.py load .env on startup; systemd units load it
# as an EnvironmentFile.

# Required to run bot.py — get a fresh token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram chat_ids that get the admin view (/usage globals,
# /quota roster, /resetquota) and bypass the free-tier limit. Find yours with
# the /whoami command. Optional — unset means no admins.
# AIDEA_ADMIN_CHAT_IDS=

# Free idea generations per user before the subscription wall. Brews and
# admins don't count. Defaults to 10.
# AIDEA_FREE_LIMIT=10

# Diverse critic panel (4 biased critics averaged, Hong–Page) on EVERY
# generation. The refine path already uses the panel for everyone regardless
# of this flag; this global switch extends it to all scoring and costs 4×
# critic calls per idea. Reserved as a PAID-TIER feature — leave unset for
# free users. Defaults off.
# AIDEA_CRITIC_PANEL=1

# Monitoring supergroup the bot mirrors activity into (every generation,
# subscription inquiries, errors). Must be a *forum* with the bot granted
# "Manage Topics" so it can file each event type under its own topic; falls
# back to the General topic otherwise. Optional — unset disables the feed.
# AIDEA_LOG_CHAT_ID=-1003900469691

# Web app bind. Use 0.0.0.0 to expose on all interfaces (behind a firewall
# or reverse proxy). Defaults to 127.0.0.1:8000 if these are unset.
AIDEA_HOST=127.0.0.1
AIDEA_PORT=8000

# Default model identifier the synthesizer should target. Optional —
# overridden per-request by the web UI / Telegram /set model=X. Defaults
# to claude-opus-4-7 in code if unset.
# AIDEA_MODEL=claude-opus-4-7

# Optional. The pipeline normally inherits its model auth from the agent
# CLI's interactive session (claude login). Set this only if you want to
# bypass the CLI and use an API key directly.
# ANTHROPIC_API_KEY=
