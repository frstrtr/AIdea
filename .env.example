# Copy this file to .env (which is gitignored) and fill in real values.
# Both server.py and bot.py load .env on startup; systemd units load it
# as an EnvironmentFile.

# Required to run bot.py — get a fresh token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# Web app bind. Use 0.0.0.0 to expose on all interfaces (behind a firewall
# or reverse proxy). Defaults to 127.0.0.1:8000 if these are unset.
AIDEA_HOST=127.0.0.1
AIDEA_PORT=8000

# Default model identifier the synthesizer should target. Optional —
# overridden per-request by the web UI / Telegram /set model=X. Defaults
# to claude-opus-4-7 in code if unset.
# AIDEA_MODEL=claude-opus-4-7

# Optional. The pipeline normally inherits its model auth from the agent
# CLI's interactive session (claude login). Set this only if you want to
# bypass the CLI and use an API key directly.
# ANTHROPIC_API_KEY=
